# ============================================================
# UAI Platform — Variables de Entorno para Producción (Railway)
# ============================================================
# INSTRUCCIONES:
# 1. Copia este archivo como referencia al configurar variables en Railway.
# 2. NUNCA subas este archivo con valores reales al repositorio.
# 3. Configura cada variable en Railway > Settings > Variables.
# ============================================================

# --- AUTENTICACIÓN (NextAuth v5) ---
# Genera con: openssl rand -base64 32
AUTH_SECRET=REEMPLAZAR_CON_SECRETO_SEGURO
# URL pública de tu app en Railway (se obtiene tras el primer despliegue)
AUTH_URL=https://tu-app.up.railway.app
AUTH_TRUST_HOST=true

# --- MODELOS DE IA ---
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_GENERATIVE_AI_API_KEY=AIza...

# --- BASE DE DATOS (Railway PostgreSQL) ---
# Railway inyecta DATABASE_URL automáticamente al agregar el servicio PostgreSQL
DATABASE_URL=postgresql://user:pass@host:port/dbname

# --- MEMORIA COGNITIVA (Pinecone) ---
PINECONE_API_KEY=pcsk_...
PINECONE_ENVIRONMENT=us-east-1-aws
PINECONE_INDEX_NAME=uai-memory

# --- PAGOS: STRIPE ---
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...

# --- PAGOS: MERCADO PAGO (LATAM) ---
MP_ACCESS_TOKEN=APP_USR-...

# --- OBSERVABILIDAD ---
# Sentry (se configura automáticamente con SENTRY_AUTH_TOKEN en build)
SENTRY_AUTH_TOKEN=sntrys_...
SENTRY_DSN=https://...@sentry.io/...

# LangSmith (para trazas de agentes)
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=lsv2_...
LANGCHAIN_PROJECT=uai-platform-prod

# --- CANALES DE MENSAJERÍA ---
# WhatsApp (Twilio)
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# Telegram
TELEGRAM_BOT_TOKEN=...

# --- SEGURIDAD Y ADMINISTRACIÓN ---
ADMIN_EMAIL=admin@uai.ai
ADMIN_PASSWORD=REEMPLAZAR_CON_CONTRASEÑA_SEGURA
SETUP_SECRET=REEMPLAZAR_CON_SECRETO_SEGURO

# Worker remoto
REMOTE_EXECUTE_SECRET=REEMPLAZAR_CON_SECRETO_SEGURO
REMOTE_EXECUTE_WORKER_TOKEN=REEMPLAZAR_CON_TOKEN_SEGURO

# --- BÚSQUEDA WEB (Opcional) ---
SERPER_API_KEY=...
TAVILY_API_KEY=tvly-...
