# --- IA MODELS (API Keys) ---
OPENAI_API_KEY=your_key_here
ANTHROPIC_API_KEY=your_key_here
GOOGLE_GENERATIVE_AI_API_KEY=your_key_here

# --- OBSERVABILITY (LangSmith) ---
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your_key_here
LANGCHAIN_PROJECT="uai-platform"

# --- PERSISTENCE (PostgreSQL) ---
DATABASE_URL=postgresql://user:pass@host:port/dbname

# --- COGNITIVE MEMORY (Pinecone) ---
PINECONE_API_KEY=your_key_here
PINECONE_ENVIRONMENT=your_env_here
PINECONE_INDEX_NAME=uai-memory

# --- PRODUCTION SECURITY (NextAuth v5) ---
AUTH_SECRET=your_random_secret_here
AUTH_URL=http://localhost:3000

# --- ADMIN CREDENTIALS (UAI Platform) ---
ADMIN_EMAIL=admin@uai.ai
ADMIN_PASSWORD=change_me_securely
SETUP_SECRET=change_me_securely

# --- OPTIONAL SKILLS ---
SERPER_API_KEY=your_key_here
SENTRY_DSN=your_sentry_dsn_here