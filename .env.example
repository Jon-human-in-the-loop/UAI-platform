# =============================================================================
# UAI PLATFORM — Variables de Entorno
# Copia este archivo como .env.local para desarrollo local.
# En producción (Vercel), carga estas variables en el panel de Environment Variables.
# =============================================================================

# =============================================================================
# CORE — OBLIGATORIAS (sin estas el servidor no arranca correctamente)
# =============================================================================

# Base de datos PostgreSQL (Neon recomendado — soporta pgvector nativamente)
# Usa el endpoint CON pooling para Vercel (serverless): ep-xxx-pooler.region.aws.neon.tech
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# Secreto de sesión NextAuth v5 — genera uno con: openssl rand -base64 32
AUTH_SECRET=genera_un_secreto_aleatorio_aqui

# URL pública de la app (sin slash final)
NEXT_PUBLIC_APP_URL=https://tu-dominio.com

# =============================================================================
# MODELOS DE IA — OBLIGATORIAS para el funcionamiento del orquestador
# =============================================================================

# OpenAI — OBLIGATORIA: usada para GPT-4o (orquestador) y embeddings de memoria (text-embedding-3-small)
OPENAI_API_KEY=sk-...

# Anthropic / Claude — Para el Prompt Optimizer (claude-haiku-4-5)
# Sin esta clave, el botón "Generar con IA" en la creación de agentes no funcionará.
ANTHROPIC_API_KEY=sk-ant-...

# Google Gemini — Modelo alternativo en el ejecutor de agentes (gemini-1.5-flash)
# Opcional: si no se configura, el ejecutor usa GPT-4o como fallback.
GOOGLE_GENERATIVE_AI_API_KEY=AIza...

# =============================================================================
# PAGOS — Configura al menos uno para monetizar la plataforma
# =============================================================================

# Stripe (recomendado para mercados internacionales)
# Obtén tus claves en: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_...          # o sk_test_... para pruebas
STRIPE_WEBHOOK_SECRET=whsec_...        # En Stripe Dashboard → Webhooks → Signing Secret
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...

# Mercado Pago (para Argentina y LATAM)
# Obtén tu token en: https://www.mercadopago.com/developers/panel/app
MP_ACCESS_TOKEN=APP_USR-...

# =============================================================================
# CANALES DE COMUNICACIÓN — Configurar según los canales que actives
# =============================================================================

# Twilio — Para envío/recepción de mensajes de WhatsApp Business
# Cuenta en: https://www.twilio.com → Console → Account SID / Auth Token
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_WHATSAPP_NUMBER=+14155238886   # Tu número de Twilio con WhatsApp habilitado

# Telegram — Un token por bot (cada usuario puede configurar el suyo propio en el dashboard)
# Bot global del sistema (opcional):
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrSTUvwxyz

# Discord — Para el bot de slash commands
# Obtén estas claves en: https://discord.com/developers/applications → tu app
DISCORD_PUBLIC_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
DISCORD_APPLICATION_ID=000000000000000000

# =============================================================================
# SCHEDULER (TAREAS PROGRAMADAS)
# =============================================================================

# Secreto para proteger el endpoint /api/scheduler/run
# Vercel Cron lo usa automáticamente si la variable se llama CRON_SECRET.
# Genera uno con: openssl rand -hex 32
CRON_SECRET=genera_un_secreto_hex_aqui

# =============================================================================
# ADMIN — Credenciales del administrador de la plataforma
# =============================================================================

# Email y contraseña del usuario admin creado por /api/admin/setup
ADMIN_EMAIL=admin@tudominio.com
ADMIN_PASSWORD=contraseña_segura_aqui

# Secreto para proteger el endpoint /api/admin/setup
SETUP_SECRET=otro_secreto_aleatorio_aqui

# =============================================================================
# OBSERVABILIDAD — Opcionales pero recomendadas en producción
# =============================================================================

# Sentry — Monitoreo de errores en tiempo real
# Obtén tu DSN en: https://sentry.io → Settings → Projects → Client Keys
SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
SENTRY_AUTH_TOKEN=sntrys_...           # Para subir source maps en el build

# LangSmith — Trazado de ejecuciones LangGraph (útil para debugging del orquestador)
# Obtén tu clave en: https://smith.langchain.com → Settings → API Keys
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=lsv2_pt_...
LANGCHAIN_PROJECT=uai-platform

# =============================================================================
# BÚSQUEDA WEB (SKILLS DEL ORQUESTADOR) — Opcionales
# =============================================================================

# Serper — Google Search para el skill "search" del orquestador
# Obtén tu clave en: https://serper.dev
SERPER_API_KEY=xxx

# Tavily — Búsqueda web alternativa
# Obtén tu clave en: https://tavily.com
TAVILY_API_KEY=tvly-...
